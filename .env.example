# ──────────────────────────────────────────────
# ZeroCostBrain — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to `.env` and customize as needed.
# All values below are the defaults.

# Path to your Obsidian knowledge base vault
# BRAIN_VAULT_PATH=C:\Users\acer.nitrov15\OneDrive\Documents\New_Life_2\knowledge_base

# LLM Provider: "LOCAL" (Ollama) or "GEMINI" (Google Cloud)
# BRAIN_LLM_PROVIDER=LOCAL

# Local Ollama settings
# Default: qwen3.5:4b — optimized for RTX 4050 (6GB VRAM).
# If you have 8GB+ VRAM, try qwen2.5:7b with BRAIN_CONTEXT_WINDOW=32768.
# OLLAMA_HOST=http://localhost:11434
# BRAIN_LOCAL_MODEL=qwen3.5:4b
# BRAIN_EMBED_MODEL=nomic-embed-text
# BRAIN_CONTEXT_WINDOW=8192

# Google Gemini (only needed if BRAIN_LLM_PROVIDER=GEMINI)
# GOOGLE_API_KEY=your_key_here
# BRAIN_GEMINI_MODEL=gemini-1.5-flash

# Indexer settings
# BRAIN_CHUNK_SIZE=4000
# BRAIN_INDEX_MAX_RETRIES=3
